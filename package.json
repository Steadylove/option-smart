{
  "name": "option-smart",
  "version": "0.1.0",
  "private": true,
  "description": "OptionSmart - AI-powered option selling strategy assistant",
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "frontend/**/*.{json,css,md}": [
      "prettier --write"
    ],
    "backend/**/*.py": [
      ".venv/bin/ruff format",
      ".venv/bin/ruff check --fix"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1"
  }
}
